# ─────────────────────────────────────────────────────────────
# TEAMOFF BACKEND — Variables d'environnement requises
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS commiter le fichier .env.
# ─────────────────────────────────────────────────────────────

# Serveur
PORT=5500
NODE_ENV=development   # development | production | test

# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/teamoff"

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_random_64_bytes_hex
JWT_REFRESH_SECRET=CHANGE_ME_generate_random_64_bytes_hex

# Emails (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=votre@email.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx   # Google App Password (pas le mot de passe du compte)
EMAIL_NAME=TeamOff SaaS
EMAIL_FROM=votre@email.com

# Super Admin (seed initial — changer immédiatement après le premier démarrage)
SUPER_ADMIN_EMAIL=admin@votredomaine.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password
SUPER_ADMIN_PRENOM=Admin
SUPER_ADMIN_NAME=TeamOff

# CORS — liste des origines frontend autorisées, séparées par des virgules
# Dev  : http://localhost:3001,http://localhost:5173
# Prod : https://votre-frontend.vercel.app
FRONTEND_URL=https://votre-frontend.vercel.app,http://localhost:3001,http://localhost:5173

# API externe jours fériés nationaux (Nager.Date — public, sans clé)
NAGER_API_URL=https://date.nager.at/api/v3

# Optionnel — chemin vers pg_dump si non détecté automatiquement
# PG_DUMP_BIN=/usr/local/bin/pg_dump
